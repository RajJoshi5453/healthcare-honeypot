# IoT Deception Honeypot Network — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose or the parsers.
# NO real secrets or credentials should be stored here; use your actual .env file.

# ------------------------------------------------------------------
# Elasticsearch / ELK Stack
# ------------------------------------------------------------------
# Hostname or IP where Elasticsearch is reachable.
# Inside Docker Compose, this is the service name: elasticsearch
# For host-based scripts, it may be localhost:9200
ELASTIC_HOST=http://elasticsearch:9200

# ------------------------------------------------------------------
# Cowrie Log Path
# ------------------------------------------------------------------
# Path to the live Cowrie JSON log file.
# Inside the Logstash container: /var/log/cowrie/cowrie.json
# On the host (if running parser.py outside Docker): infrastructure/cowrie-logs/cowrie.json
COWRIE_LOG_PATH=../infrastructure/cowrie-logs/cowrie.json

# ------------------------------------------------------------------
# Flask Dashboard
# ------------------------------------------------------------------
# Port on which the Flask dashboard listens.
# If running in Docker, this is exposed on the host via docker-compose.yml.
FLASK_PORT=5000

# ------------------------------------------------------------------
# IoC / Analysis Paths (optional overrides)
# ------------------------------------------------------------------
# Intermediate parsed sessions JSON (written by parser.py, read by ioc_extractor.py)
PARSED_SESSIONS_PATH=../analysis/parsed_sessions.json

# Final enriched attack patterns report (used by Flask dashboard and geoip_enricher)
ATTACK_PATTERNS_PATH=../analysis/attack_patterns.json

# ------------------------------------------------------------------
# GeoIP Rate Limiting (seconds between requests)
# ------------------------------------------------------------------
# ip-api.com free tier allows ~45 requests/minute from one IP.
# Keep this at 1.0 or higher to avoid being blocked.
GEOIP_DELAY=1.0
