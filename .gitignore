# IoT Honeypot Network - Git Ignore
# Purpose: Prevent secrets, malware samples, runtime logs, and Python cache
# from being accidentally committed to the repository.

# Environment variables and secrets
.env
.env.local
.env.*.local

# Malware samples collected from attackers
# These are dangerous binaries and should NEVER be committed.
analysis/malware_samples/
analysis/malware_samples/*

# Log files generated by Cowrie or the host
*.log
*.log.*
cowrie.json
cowrie.json.*

# Python runtime cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments (if created locally for testing)
venv/
.venv/
env/
ENV/

# IDE and editor artifacts
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Cowrie internal database and downloaded files
# (These are container runtime artifacts, not source code)
cowrie.db
*.db
var/
downloads/

# Elastic stack runtime data (if accidentally mounted into repo)
es-data/
